// AssetFlow — Prisma Schema
// Authoritative data model — keep docs/data-model.md in sync

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DeptStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum ScopeType {
  DEPARTMENT
  LOCATION
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_APPROVED
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(EMPLOYEE)
  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations — allocations received
  allocations          Allocation[]          @relation("AllocatedTo")
  allocationsPerformed Allocation[]          @relation("AllocatedBy")

  // Transfers
  transfersFrom TransferRequest[] @relation("TransferFrom")
  transfersTo   TransferRequest[] @relation("TransferTo")
  transfersApproved TransferRequest[] @relation("TransferApprovedBy")

  // Bookings
  bookings Booking[]

  // Maintenance
  maintenanceRequests   MaintenanceRequest[] @relation("MaintenanceRequestedBy")
  maintenanceAssigned   MaintenanceRequest[] @relation("MaintenanceTechnician")
  maintenanceApprovals  MaintenanceRequest[] @relation("MaintenanceApprovedBy")

  // Audit
  auditCyclesCreated AuditCycle[]   @relation("AuditCreatedBy")
  auditVerifications AuditItem[]    @relation("AuditVerifiedBy")
  auditAssignments   AuditCycle[]   @relation("AuditAuditors")

  // Notifications & Activity
  notifications Notification[]
  activityLogs  ActivityLog[]

  // Department head
  departmentsHeaded Department[] @relation("DepartmentHead")

  // Password reset
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?

  // Refresh token (hashed)
  refreshTokenHash String?

  @@index([email])
  @@index([departmentId])
  @@index([role])
}

model Department {
  id       String     @id @default(uuid())
  name     String     @unique
  parentId String?
  parent   Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")
  headId   String?
  head     User?      @relation("DepartmentHead", fields: [headId], references: [id])
  status   DeptStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Members
  members User[] @relation("DepartmentMembers")

  // Assets owned by this department
  assets Asset[] @relation("AssetDepartment")

  // Allocations to this department
  allocations Allocation[]

  // Audit cycles scoped to this department
  auditCycles AuditCycle[]

  @@index([parentId])
}

model AssetCategory {
  id           String @id @default(uuid())
  name         String @unique
  description  String?
  customFields Json   @default("[]") // Array of { fieldName, fieldType, required }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id              String      @id @default(uuid())
  name            String
  assetTag        String      @unique // Auto-generated: AF-0001, AF-0002, ...
  serialNumber    String?
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  departmentId    String?
  department      Department?  @relation("AssetDepartment", fields: [departmentId], references: [id])
  status          AssetStatus  @default(AVAILABLE)
  acquisitionDate DateTime
  acquisitionCost Decimal?     @db.Decimal(12, 2) // For reporting only, NOT accounting
  condition       String       @default("Good")
  location        String?
  isBookable      Boolean      @default(false) // Shared/bookable resource flag
  photos          Json         @default("[]")   // Array of file URLs
  documents       Json         @default("[]")   // Array of file URLs
  customFieldValues Json       @default("{}")   // Values for category-specific custom fields
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  @@index([assetTag])
  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([serialNumber])
}

model Allocation {
  id                   String           @id @default(uuid())
  assetId              String
  asset                Asset            @relation(fields: [assetId], references: [id])
  userId               String
  user                 User             @relation("AllocatedTo", fields: [userId], references: [id])
  departmentId         String?
  department           Department?      @relation(fields: [departmentId], references: [id])
  status               AllocationStatus @default(ACTIVE)
  allocatedAt          DateTime         @default(now())
  expectedReturnDate   DateTime?
  returnedAt           DateTime?
  returnConditionNotes String?
  allocatedById        String
  allocatedBy          User             @relation("AllocatedBy", fields: [allocatedById], references: [id])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Transfer requests on this allocation
  transferRequests TransferRequest[]

  @@index([assetId, status])
  @@index([userId])
  @@index([expectedReturnDate])
}

model TransferRequest {
  id           String         @id @default(uuid())
  allocationId String
  allocation   Allocation     @relation(fields: [allocationId], references: [id])
  fromUserId   String
  fromUser     User           @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUserId     String
  toUser       User           @relation("TransferTo", fields: [toUserId], references: [id])
  status       TransferStatus @default(REQUESTED)
  reason       String?
  requestedAt  DateTime       @default(now())
  approvedById String?
  approvedBy   User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([allocationId])
  @@index([status])
}

model Booking {
  id          String        @id @default(uuid())
  assetId     String
  asset       Asset         @relation(fields: [assetId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  startTime   DateTime      @db.Timestamptz()
  endTime     DateTime      @db.Timestamptz()
  status      BookingStatus @default(UPCOMING)
  purpose     String?
  cancelledAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // DB-level exclusion constraint added via migration SQL:
  // EXCLUDE USING gist ("assetId" WITH =, tstzrange("startTime", "endTime", '[)') WITH &&)
  // WHERE (status != 'CANCELLED')

  @@index([assetId, startTime, endTime])
  @@index([userId])
  @@index([status])
}

model MaintenanceRequest {
  id            String            @id @default(uuid())
  assetId       String
  asset         Asset             @relation(fields: [assetId], references: [id])
  requestedById String
  requestedBy   User              @relation("MaintenanceRequestedBy", fields: [requestedById], references: [id])
  description   String
  priority      Priority          @default(MEDIUM)
  status        MaintenanceStatus @default(PENDING)
  attachments   Json              @default("[]") // Array of file URLs
  technicianId  String?
  technician    User?             @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  approvedById  String?
  approvedBy    User?             @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
  resolvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([requestedById])
}

model AuditCycle {
  id           String           @id @default(uuid())
  name         String
  scopeType    ScopeType
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id])
  location     String?
  startDate    DateTime
  endDate      DateTime
  status       AuditCycleStatus @default(PLANNED)
  createdById  String
  createdBy    User             @relation("AuditCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Auditors assigned to this cycle
  auditors User[] @relation("AuditAuditors")

  // Items to audit
  items AuditItem[]

  @@index([status])
  @@index([departmentId])
}

model AuditItem {
  id           String          @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle      @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset           @relation(fields: [assetId], references: [id])
  status       AuditItemStatus @default(PENDING)
  notes        String?
  verifiedById String?
  verifiedBy   User?           @relation("AuditVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([auditCycleId, assetId]) // One item per asset per cycle
  @@index([auditCycleId])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // e.g., ASSET_CREATED, ALLOCATION_MADE, ROLE_PROMOTED
  entityType String   // e.g., Asset, User, Booking
  entityId   String
  details    Json     @default("{}")
  createdAt  DateTime @default(now())

  // NO updatedAt — append-only, never modified

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}

// ─── Asset Tag Counter ──────────────────────────────────────────────────────
// Used for auto-generating sequential asset tags (AF-0001, AF-0002, ...)

model AssetTagCounter {
  id      String @id @default("singleton")
  counter Int    @default(0)
}
